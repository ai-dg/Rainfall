	int var1; /* stored at object +0x68 in the subject build (constructor: mov to 0x68(%eax)) */

	N(int param1)
	{
		this->var1 = param1;
	}

	void setAnnotation(char *p)
	{
		memcpy(this->buf, p, strlen(p)); /* BUG: no upper bound → overflow into next heap chunk / vptr */
	}

	virtual int operator+(N *p) { return this->var1 + p->var1; }
	virtual int operator-(N *p) { return this->var1 - p->var1; }
