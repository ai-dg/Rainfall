/*
 * Level8 reconstruction (Rainfall).
 * Loop: auth (malloc(4) + strcpy with no real limit), reset (free auth),
 * service (strdup), login (if *(auth+0x20) != 0 → system("/bin/sh")).
 * Exploit: short auth, then service with long string so auth+0x20
 * falls inside the service buffer.
 */

#include <stdlib.h>
#include <stdio.h>
#include <string.h>

static char *auth;
static char *service;

int main(void)
{
	char buf[0x80]; /* 128 bytes */

	while (1) {
		printf("%p, %p \n", auth, service);
		if (!fgets(buf, 0x80, stdin)) /* 128 bytes */
			break;
		if (strncmp(buf, "auth ", 5) == 0) {
			auth = malloc(4);
			*auth = 0;
			if (strlen(buf + 5) <= 0x1e) /* 30 bytes max */
				strcpy(auth, buf + 5);  /* overflow */
		} else if (strncmp(buf, "reset", 5) == 0) {
			free(auth);
		} else if (strncmp(buf, "service", 6) == 0) {
			service = strdup(buf + 7);
		} else if (strncmp(buf, "login", 5) == 0) {
			if (*(auth + 0x20)) /* auth + 32: out-of-bounds read */
				system("/bin/sh");
			else
				fwrite("Password:\n", 1, 10, stdout);
			break;
		}
	}
	return 0;
}
